                                                                    Tag="{Binding}"
                                                                    Click="RemoveLongTaskBtn_Click"
                                                                    ToolTip="删除长期任务"
                                                                    Width="24"
                                                                    Height="24"
                                                                    MinWidth="24"
                                                                    Padding="0"
                                                                    Style="{StaticResource ToolbarButton}">
                                                                <Path Width="10" Height="10"
                                                                      Style="{StaticResource ButtonIconStrokePath}"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                      StrokeThickness="2"
                                                                      Data="M 2 2 L 8 8 M 8 2 L 2 8"/>
                                                            </Button>
                                                        </Grid>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="LongTaskTextChanged"
                                                                 PreviewKeyDown="LongTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTextBox}"
                                                                 Margin="0,8,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <TextBlock Text="出现方式"
                                                                       Style="{StaticResource TaskTimeUnitText}"
                                                                       Margin="0,0,8,0"/>
                                                            <ComboBox Width="148"
                                                                      SelectedValue="{Binding TaskType, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectedValuePath="Tag"
                                                                      SelectionChanged="LongTaskSelectionChanged"
                                                                      Style="{StaticResource PanelComboBox}">
                                                                <ComboBoxItem Content="手动加入" Tag="Progress"/>
                                                                <ComboBoxItem Content="周期任务" Tag="Recurring"/>
                                                            </ComboBox>
                                                        </StackPanel>
                                                        <Border Visibility="{Binding ProgressSettingsVisibility}"
                                                                Margin="0,10,0,0"
                                                                Padding="10"
                                                                Background="#161B20"
                                                                BorderBrush="#34404A"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="进度格式"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <ComboBox Width="116"
                                                                              SelectedValue="{Binding ProgressMode, UpdateSourceTrigger=PropertyChanged}"
                                                                              SelectedValuePath="Tag"
                                                                              SelectionChanged="LongTaskSelectionChanged"
                                                                              Style="{StaticResource PanelComboBox}">
                                                                        <ComboBoxItem Content="百分比（20%）" Tag="Percent"/>
                                                                        <ComboBoxItem Content="数量（10题）" Tag="Count"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding PercentProgressVisibility}"
                                                                            Margin="0,10,0,0">
                                                                    <TextBlock Text="当前进度"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <TextBox Width="52"
                                                                             MaxLength="3"
                                                                             Text="{Binding CurrentValueText, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                             Style="{StaticResource TaskTimeTextBox}"/>
                                                                    <TextBlock Text="%"
                                                                               Style="{StaticResource TaskTimeUnitText}"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal"
                                                                             Visibility="{Binding CountProgressVisibility}"
                                                                             Margin="0,10,0,0">
                                                                    <TextBlock Text="当前数量"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <TextBox Width="52"
                                                                             Text="{Binding CurrentValueText, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                             Style="{StaticResource TaskTimeTextBox}"/>
                                                                    <TextBox Width="54"
                                                                             Text="{Binding ProgressUnit, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                     Style="{StaticResource TaskTextBox}"
                                                                     Margin="8,0,0,0"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding CountProgressVisibility}"
                                                                            Margin="0,10,0,0">
                                                                    <TextBlock Text="每次完成增加"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <TextBox Width="52"
                                                                             Text="{Binding CompletionIncrementText, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                             Style="{StaticResource TaskTimeTextBox}"/>
                                                                    <TextBlock Text="{Binding ProgressUnit}"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="4,0,0,0"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                                    <TextBlock Text="计时方式"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <ComboBox Width="148"
                                                                              SelectedValue="{Binding TimerMode, UpdateSourceTrigger=PropertyChanged}"
                                                                              SelectedValuePath="Tag"
                                                                              SelectionChanged="LongTaskSelectionChanged"
                                                                              Style="{StaticResource PanelComboBox}">
                                                                        <ComboBoxItem Content="倒计时（自动完成）" Tag="Countdown"/>
                                                                        <ComboBoxItem Content="顺计时（手动完成）" Tag="CountUp"/>
                                                                    </ComboBox>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal"
                                                                            Visibility="{Binding CountdownSettingsVisibility}"
                                                                            Margin="0,14,0,0">
                                                                    <TextBlock Text="默认单次倒计时"
                                                                               Style="{StaticResource TaskTimeUnitText}"
                                                                               Margin="0,0,8,0"/>
                                                                    <TextBox Width="46"
                                                                             MaxLength="2"
                                                                             Text="{Binding DefaultPlannedHoursText, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                             Style="{StaticResource TaskTimeTextBox}"/>
                                                                    <TextBlock Text="小时" Style="{StaticResource TaskTimeUnitText}"/>
                                                                    <TextBox Width="46"
                                                                             MaxLength="2"
                                                                             Text="{Binding DefaultPlannedMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                                                             TextChanged="LongTaskTextChanged"
                                                                             Style="{StaticResource TaskTimeTextBox}"/>
                                                                    <TextBlock Text="分钟" Style="{StaticResource TaskTimeUnitText}"/>
                                                                </StackPanel>
                                                                <TextBlock Text="加入今日后按该时长倒计时；修改时会同步今天的关联任务，耗尽后自动完成。"
                                                                           Visibility="{Binding CountdownSettingsVisibility}"
                                                                           Foreground="#AEB8C2"
                                                                           FontSize="12"
                                                                           Margin="0,8,0,0"/>
                                                                <TextBlock Text="顺计时需手动勾选完成；数量任务会按“每次完成增加”写入累计。"
                                                                           Visibility="{Binding CountUpHelpVisibility}"
                                                                           Foreground="#AEB8C2"
                                                                           FontSize="12"
                                                                           Margin="0,8,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <CheckBox Content="记录题号（每日计划中逐条录入）"
                                                                  IsChecked="{Binding TrackProblemNumbers, UpdateSourceTrigger=PropertyChanged}"
                                                                  Click="LongTaskScheduleChanged"
                                                                  ToolTip="开启后，可在每日计划中输入任意题号内容并逐条添加。"
                                                                  Foreground="#D9E0E6"
                                                                  Margin="0,10,0,0"/>
                                                        <Border Visibility="{Binding RecurringSettingsVisibility}"
                                                                Margin="0,10,0,0"
                                                                Padding="10"
                                                                Background="#161B20"
                                                                BorderBrush="#34404A"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="周期任务会自动出现在符合日期的每日计划中；计时方式与进度记录由上方独立设置。"
                                                                           Foreground="#C8D0D8"
                                                                           TextWrapping="Wrap"/>
                                                                <WrapPanel Margin="0,10,0,0">
                                                                    <CheckBox Content="一" IsChecked="{Binding IsMonday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="二" IsChecked="{Binding IsTuesday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="三" IsChecked="{Binding IsWednesday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="四" IsChecked="{Binding IsThursday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="五" IsChecked="{Binding IsFriday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="六" IsChecked="{Binding IsSaturday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                    <CheckBox Content="日" IsChecked="{Binding IsSunday}" Checked="LongTaskScheduleChanged" Unchecked="LongTaskScheduleChanged" Style="{StaticResource WeekdayCheckBox}"/>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="备注"
                                                                   Foreground="#AEB8C2"
                                                                   FontSize="12"
                                                                   Margin="0,12,0,4"/>
                                                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="LongTaskTextChanged"
                                                                 Height="72"
                                                                 VerticalContentAlignment="Top"
                                                                 Style="{StaticResource TaskTextBox}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border x:Name="StatisticsPanel"
                                Visibility="Collapsed"
                                Background="#252D34"
                                BorderBrush="#3B4650"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="186"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="StatisticsMonthTitle"
                                               Text="统计"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#F5F1EB"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Click="ReturnToCalendarBtn_Click"
                                            ToolTip="返回日历"
                                            Width="32"
                                            MinWidth="32"
                                            Padding="0"
                                            Style="{StaticResource ToolbarButton}">
                                        <Path Width="11" Height="11"
                                              Style="{StaticResource ButtonIconStrokePath}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 7.5 1.5 L 3 5.5 L 7.5 9.5 M 3.5 5.5 L 11 5.5"/>
                                    </Button>
                                </Grid>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,18,0,12">
                                    <Border Background="#1C242B" BorderBrush="#34404A" BorderThickness="1" Padding="8" Margin="0,0,6,6">
                                        <StackPanel><TextBlock Text="实际计时" Foreground="#AEB8C2" FontSize="12"/><TextBlock x:Name="StatisticsActualText" Foreground="#F5F1EB" FontSize="16" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel>
                                    </Border>
                                    <Border Background="#1C242B" BorderBrush="#34404A" BorderThickness="1" Padding="8" Margin="6,0,0,6">
                                        <StackPanel><TextBlock Text="计划时长" Foreground="#AEB8C2" FontSize="12"/><TextBlock x:Name="StatisticsPlanText" Foreground="#F5F1EB" FontSize="16" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel>
                                    </Border>
                                    <Border Background="#1C242B" BorderBrush="#34404A" BorderThickness="1" Padding="8" Margin="0,6,6,0">
                                        <StackPanel><TextBlock Text="活跃天数" Foreground="#AEB8C2" FontSize="12"/><TextBlock x:Name="StatisticsActiveDaysText" Foreground="#F5F1EB" FontSize="16" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel>
                                    </Border>
                                    <Border Background="#1C242B" BorderBrush="#34404A" BorderThickness="1" Padding="8" Margin="6,6,0,0">
                                        <StackPanel><TextBlock Text="周期完成" Foreground="#AEB8C2" FontSize="12"/><TextBlock x:Name="StatisticsRecurringText" Foreground="#F5F1EB" FontSize="16" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel>
                                    </Border>
                                </UniformGrid>
                                <Border Grid.Row="2"
                                        Background="#151B21"
                                        BorderBrush="#3D4852"
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="算法题题号"
                                                       Foreground="#F5F1EB"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="StatisticsProblemCountText"
                                                       Grid.Column="1"
                                                       Text="暂无记录"
                                                       Foreground="#FF9D45"
                                                       FontSize="12"/>
                                        </Grid>
                                        <TextBlock x:Name="StatisticsProblemEmptyText"
                                                   Text="本月暂无题号记录"
                                                   Foreground="#8FA0AF"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="StatisticsProblemItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48"/>
                                                            <ColumnDefinition Width="92"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding DateText}" Foreground="#AEB8C2" FontSize="12"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding TaskName}" Foreground="#F5F1EB" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding ProblemNumbersText}" Foreground="#FF9D45" FontSize="12" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="3" Background="#151B21" BorderBrush="#3D4852" BorderThickness="1" Padding="8">
                                    <ItemsControl x:Name="StatisticsBarItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><UniformGrid Columns="31"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="170" VerticalAlignment="Bottom">
                                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Value}" Foreground="#AEB8C2" FontSize="8" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Row="1" Height="{Binding Height}" Background="#FF7A1A" CornerRadius="1" VerticalAlignment="Bottom" Margin="2,0"/>
                                                    <TextBlock Grid.Row="2" Text="{Binding Label}" Foreground="#AEB8C2" FontSize="8" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                            </ScrollViewer>
                        </Border>
                        </Grid>

                        <Border Grid.Column="1"
                                Background="#FF7A1A"
                                CornerRadius="1"/>

                        <Grid Grid.Column="2" Margin="28,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="230"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
