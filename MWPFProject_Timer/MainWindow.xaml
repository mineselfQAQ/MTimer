<Window x:Class="MWPFProject_Timer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MWPFProject_Timer"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown"
        Closing="Window_Closing"
        Width="256" Height="118"
        MinWidth="256" MinHeight="118"
        MaxWidth="256" MaxHeight="118">

    <Window.Resources>
        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1B1E22"/>
            <Setter Property="Background" Value="#F0F2F3"/>
            <Setter Property="BorderBrush" Value="#A8ADB2"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#F6F2EE"/>
            <Setter Property="Background" Value="#2E363E"/>
            <Setter Property="BorderBrush" Value="#4A5662"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3B4650"/>
                                <Setter Property="BorderBrush" Value="#FF7A1A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FFF5F5"/>
            <Setter Property="Background" Value="#8F2424"/>
            <Setter Property="BorderBrush" Value="#E66060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B73333"/>
                                <Setter Property="BorderBrush" Value="#FF8A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonIconStrokePath" TargetType="Path">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="StrokeThickness" Value="1.8"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
        </Style>

        <Style x:Key="ButtonIconFillPath" TargetType="Path">
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="DayButton" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF9D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B20"/>
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="CaretBrush" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#3D4852"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="TaskTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#161B20"/>
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="CaretBrush" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#3D4852"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TaskTimeTextBox" TargetType="TextBox" BasedOn="{StaticResource TaskTextBox}">
            <Setter Property="Padding" Value="2,4"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TaskTimeUnitText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8D0D8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0,6,0"/>
        </Style>

        <Style x:Key="DurationStepButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="15"/>
            <Setter Property="Padding" Value="1,0"/>
            <Setter Property="FontSize" Value="9"/>
        </Style>

        <Style x:Key="PanelComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="Background" Value="#20262C"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3B4650"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF7A1A"/>
                                <Setter Property="Foreground" Value="#1A1E22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="Background" Value="#161B20"/>
            <Setter Property="BorderBrush" Value="#3D4852"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource PanelComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                           Background="{TemplateBinding Background}"
                                           Foreground="{TemplateBinding Foreground}"
                                           BorderBrush="{TemplateBinding BorderBrush}"
                                           BorderThickness="{TemplateBinding BorderThickness}"
                                           Padding="{TemplateBinding Padding}"
                                           IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <ContentPresenter Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Width="8" Height="5"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      Fill="{TemplateBinding Foreground}"
                                                      Data="M 0 0 L 8 0 L 4 5 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="#20262C"
                                        BorderBrush="#51606D"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0">
                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                  CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto"
                                                  MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WeekdayCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D9E0E6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="RootBorder"
                BorderBrush="#555"
                BorderThickness="1"
                CornerRadius="0"
                Background="#40FFFFFF"
                Focusable="True">
            <Grid>
                <Grid x:Name="CompactPanel">
                    <Grid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="关闭"
                                      Click="CloseBtn_Click"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="TaskUpBtn"
                            Click="TaskUpBtn_Click"
                            ToolTip="上一个任务"
                            Style="{StaticResource MiniButton}">
                        <Path Width="11" Height="8"
                              Style="{StaticResource ButtonIconStrokePath}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M 1 7 L 5.5 2 L 10 7"/>
                    </Button>
                    <Button x:Name="TaskDownBtn"
                            Grid.Row="2"
                            Click="TaskDownBtn_Click"
                            ToolTip="下一个任务"
                            Style="{StaticResource MiniButton}">
                        <Path Width="11" Height="8"
                              Style="{StaticResource ButtonIconStrokePath}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M 1 1 L 5.5 6 L 10 1"/>
                    </Button>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="当前任务:"
                                   Foreground="#1B1E22"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentTaskName"
                                   Text="自由学习"
                                   Foreground="#1B1E22"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,8,0"/>
                        <TextBlock x:Name="CurrentTaskState"
                                   Text=""
                                   Foreground="#D84C4C"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,8,0"/>
                    </StackPanel>

                    <TextBlock x:Name="MinuteCounter"
                               Grid.Row="1"
                               Grid.Column="2"
                               Text="00:00"
                               Foreground="Black"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Border x:Name="CompactIndicator"
                            Grid.Column="2"
                            Width="8" Height="8"
                            Background="White"
                            Margin="0,6,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="1"/>

                    <StackPanel Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                        <Button x:Name="StartBtn"
                                Click="StartBtn_Click"
                                ToolTip="开始"
                                Style="{StaticResource MiniButton}">
                            <Path Width="10" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Style="{StaticResource ButtonIconFillPath}"
                                  Data="M 1 1 L 10 6 L 1 11 Z"/>
                        </Button>
                        <Button x:Name="StopBtn"
                                Click="StopBtn_Click"
                                ToolTip="停止"
                                Style="{StaticResource MiniButton}">
                            <Rectangle Width="10" Height="10"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="CompleteTaskBtn"
                                Click="CompleteCurrentTaskBtn_Click"
                                ToolTip="完成当前每日任务"
                                IsEnabled="False"
                                Style="{StaticResource MiniButton}">
                            <Path Width="11" Height="8"
                                  Style="{StaticResource ButtonIconStrokePath}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 1 4.5 L 4 7.5 L 10 1.5"/>
                        </Button>
                        <Button x:Name="ExpandBtn"
                                Click="ExpandBtn_Click"
                                ToolTip="展开"
                                Width="30"
                                Style="{StaticResource MiniButton}">
                            <Path Width="13" Height="13"
                                  Style="{StaticResource ButtonIconStrokePath}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 1.5 5 L 1.5 1.5 L 5 1.5 M 8 1.5 L 11.5 1.5 L 11.5 5 M 11.5 8 L 11.5 11.5 L 8 11.5 M 5 11.5 L 1.5 11.5 L 1.5 8"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ExpandedPanel"
                      Visibility="Collapsed"
                      Background="#20262C">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="22,10,22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border x:Name="ExpandedIndicator"
                                    Width="9" Height="9"
                                    Background="White"
                                    CornerRadius="2"
                                    Margin="0,0,8,0"/>
                            <TextBlock x:Name="ExpandedMinuteCounter"
                                       Text="00:00"
                                       FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="#F5F1EB"
                                        VerticalAlignment="Center"/>
                            <TextBlock Text="当前："
                                       FontSize="13"
                                       Foreground="#AEB8C2"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                            <TextBlock x:Name="ExpandedCurrentTaskName"
                                       Text="自由学习"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F1EB"
                                       VerticalAlignment="Center"
                                       MaxWidth="160"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Click="StartBtn_Click"
                                    ToolTip="开始当前任务"
                                    Width="32"
                                    MinWidth="32"
                                    Padding="0"
                                    Margin="14,0,6,0"
                                    Style="{StaticResource ToolbarButton}">
                                <Path Width="10" Height="12"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Style="{StaticResource ButtonIconFillPath}"
                                      Data="M 1 1 L 10 6 L 1 11 Z"/>
                            </Button>
                            <Button Click="StopBtn_Click"
                                    ToolTip="停止计时"
                                    Width="32"
                                    MinWidth="32"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource ToolbarButton}">
                                <Rectangle Width="10" Height="10"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Button>
                        </StackPanel>

                        <Button Grid.Column="2"
                                x:Name="StatsBtn"
                                Click="StatsBtn_Click"
                                ToolTip="查看统计"
                                Width="32"
                                MinWidth="32"
                                Padding="0"
                                Margin="0,0,8,0"
                                Style="{StaticResource ToolbarButton}">
                            <Path Width="13" Height="13"
                                  Style="{StaticResource ButtonIconStrokePath}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 1.5 11.5 L 1.5 1.5 M 1.5 11.5 L 12 11.5 M 4 9 L 6 6.5 L 8 8 L 11 3"/>
                        </Button>
                        <Button Grid.Column="3"
                                x:Name="CollapseBtn"
                                Click="CollapseBtn_Click"
                                ToolTip="收起"
                                Width="32"
                                MinWidth="32"
                                Padding="0"
                                Style="{StaticResource ToolbarButton}">
                            <Path Width="13" Height="13"
                                  Style="{StaticResource ButtonIconStrokePath}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M 1.5 1.5 L 5 5 M 5 1.5 L 5 5 L 1.5 5 M 11.5 1.5 L 8 5 M 8 1.5 L 8 5 L 11.5 5 M 11.5 11.5 L 8 8 M 8 11.5 L 8 8 L 11.5 8 M 1.5 11.5 L 5 8 M 5 11.5 L 5 8 L 1.5 8"/>
                        </Button>
                        <Button Grid.Column="4"
                                x:Name="CloseBtn"
                                Click="CloseBtn_Click"
                                ToolTip="关闭"
                                Width="32"
                                MinWidth="32"
                                Padding="0"
                                Margin="8,0,0,0"
                                Style="{StaticResource DangerToolbarButton}">
                            <Path Width="12" Height="12"
                                  Style="{StaticResource ButtonIconStrokePath}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  Data="M 2 2 L 10 10 M 10 2 L 2 10"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="22,14,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="540"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                        <Border x:Name="CalendarPanel"
                                 Background="#252D34"
                                BorderBrush="#3B4650"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Click="PrevMonthBtn_Click"
                                            ToolTip="上个月"
                                            Width="32"
                                            MinWidth="32"
                                            Padding="0"
                                            Style="{StaticResource ToolbarButton}">
                                        <Path Width="8" Height="12"
                                              Style="{StaticResource ButtonIconStrokePath}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 7 1 L 2 6 L 7 11"/>
                                    </Button>
                                    <TextBlock x:Name="MonthTitle"
                                               Grid.Column="1"
                                               Text="2026年6月"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#F5F1EB"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Click="NextMonthBtn_Click"
                                            ToolTip="下个月"
                                            Width="32"
                                            MinWidth="32"
                                            Padding="0"
                                            Style="{StaticResource ToolbarButton}">
                                        <Path Width="8" Height="12"
                                              Style="{StaticResource ButtonIconStrokePath}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 1 1 L 6 6 L 1 11"/>
                                    </Button>
                                </Grid>

                                <UniformGrid Grid.Row="1"
                                             Columns="7"
                                             Margin="0,20,0,8">
                                    <TextBlock Text="一" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="二" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="三" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="四" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="五" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="六" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="日" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </UniformGrid>

                                <ItemsControl x:Name="CalendarDayItems"
                                              Grid.Row="2">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" Rows="6"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource DayButton}"
                                                    Click="CalendarDay_Click"
                                                    Tag="{Binding Date}"
                                                    Background="{Binding Background}"
                                                    BorderBrush="{Binding BorderBrush}">
                                                <Grid>
                                                    <TextBlock Text="{Binding DayText}"
                                                               Foreground="{Binding Foreground}"
                                                               FontWeight="{Binding FontWeight}"
                                                               Margin="8,6,0,0"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding TimeText}"
                                                               Foreground="{Binding TimeForeground}"
                                                               Visibility="{Binding TimeVisibility}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,18,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Ellipse Width="5" Height="5"
                                                             Fill="{Binding DotBrush}"
                                                             Visibility="{Binding DotVisibility}"
                                                             Margin="0,0,8,7"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border x:Name="LongTaskFocusPanel"
                                Visibility="Collapsed"
                                Background="#252D34"
                                BorderBrush="#3B4650"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="长期任务详情"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#F5F1EB"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Click="AddLongTaskBtn_Click"
                                            ToolTip="添加长期任务"
                                            Width="32"
                                            MinWidth="32"
                                            Padding="0"
                                            Style="{StaticResource ToolbarButton}">
                                        <Path Width="12" Height="12"
                                              Style="{StaticResource ButtonIconStrokePath}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 6 1.5 L 6 10.5 M 1.5 6 L 10.5 6"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Click="ReturnToCalendarBtn_Click"
                                            ToolTip="返回日历"
                                            Width="32"
                                            MinWidth="32"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ToolbarButton}">
                                        <Path Width="11" Height="11"
                                              Style="{StaticResource ButtonIconStrokePath}"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 7.5 1.5 L 3 5.5 L 7.5 9.5 M 3.5 5.5 L 11 5.5"/>
                                    </Button>
                                </Grid>
                                <ScrollViewer Grid.Row="1"
                                              Margin="0,16,0,0"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="LongTaskFocusItems">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1C242B"
                                                        BorderBrush="#2F3A44"
                                                        BorderThickness="1"
                                                        Padding="12"
                                                        Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="任务设置"
                                                                       Foreground="#AEB8C2"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"/>
