                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
