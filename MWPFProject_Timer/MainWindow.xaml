                                                                    Padding="0"
                                                                    Margin="6,0,0,0">
                                                                <Path Width="15" Height="12"
                                                                      Style="{StaticResource ButtonIconStrokePath}"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                      Data="M 1.5 6 L 8.5 6 M 6 3.5 L 8.5 6 L 6 8.5 M 10.5 2 L 13.5 2 L 13.5 10 L 10.5 10"/>
                                                            </Button>
                                                            <Button Grid.Column="4"
                                                                    Tag="{Binding}"
                                                                    Click="RemoveTaskBtn_Click"
                                                                    IsEnabled="{Binding CanEdit}"
                                                                    Visibility="{Binding RemoveButtonVisibility}"
                                                                    ToolTip="删除任务"
                                                                    Style="{StaticResource ToolbarButton}"
                                                                    Width="24"
                                                                    Height="30"
                                                                    MinWidth="24"
                                                                    Padding="0"
                                                                    Margin="6,0,0,0">
                                                                <Path Width="10" Height="10"
                                                                      Style="{StaticResource ButtonIconStrokePath}"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                      StrokeThickness="2"
                                                                      Data="M 2 2 L 8 8 M 8 2 L 2 8"/>
                                                            </Button>
                                                        </Grid>

                                                        <Grid Grid.Row="2"
                                                              Visibility="{Binding ProblemNumbersVisibility}"
                                                              Margin="0,8,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="题号"
                                                                       Style="{StaticResource TaskTimeUnitText}"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBox Grid.Column="1"
                                                                     Text="{Binding ProblemNumberInput, UpdateSourceTrigger=PropertyChanged}"
                                                                     IsReadOnly="{Binding IsProblemNumberInputReadOnly}"
                                                                     ToolTip="输入任意题号内容后，选择右侧的正确或错误"
                                                                     Style="{StaticResource TaskTextBox}"/>
                                                            <StackPanel Grid.Column="2"
                                                                        Orientation="Horizontal"
                                                                        Margin="6,0,0,0">
                                                                <Button Tag="{Binding}"
                                                                        Click="AddCorrectProblemNumberBtn_Click"
                                                                        IsEnabled="{Binding CanEdit}"
                                                                        ToolTip="记录正确题"
                                                                        Style="{StaticResource ToolbarButton}"
                                                                        Width="26"
                                                                        Height="30"
                                                                        MinWidth="26"
                                                                        Padding="0">
                                                                    <Path Width="12"
                                                                          Height="12"
                                                                          Stroke="#2FB344"
                                                                          StrokeThickness="2"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round"
                                                                          StrokeLineJoin="Round"
                                                                          Data="M 1 6 L 4.5 9.5 L 11 2"/>
                                                                </Button>
                                                                <Button Tag="{Binding}"
                                                                        Click="AddWrongProblemNumberBtn_Click"
                                                                        IsEnabled="{Binding CanEdit}"
                                                                        ToolTip="记录错误题"
                                                                        Style="{StaticResource ToolbarButton}"
                                                                        Width="26"
                                                                        Height="30"
                                                                        MinWidth="26"
                                                                        Padding="0"
                                                                        Margin="4,0,0,0">
                                                                    <Grid Width="12" Height="12">
                                                                        <Ellipse Stroke="#E25555" StrokeThickness="1.6"/>
                                                                        <Path Stroke="#E25555"
                                                                              StrokeThickness="1.6"
                                                                              StrokeStartLineCap="Round"
                                                                              StrokeEndLineCap="Round"
                                                                              Data="M 3.25 3.25 L 8.75 8.75 M 8.75 3.25 L 3.25 8.75"/>
                                                                    </Grid>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <ItemsControl Grid.Row="3"
                                                                      ItemsSource="{Binding ProblemNumberEntries}"
                                                                      Visibility="{Binding ProblemNumberEntriesVisibility}"
                                                                      Margin="0,6,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#253039"
                                                                            BorderBrush="#3D4852"
                                                                            BorderThickness="1"
                                                                            CornerRadius="3"
                                                                            Padding="6,3"
                                                                            Margin="0,0,5,5">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Grid Width="10"
                                                                                  Height="10"
                                                                                  Margin="0,0,4,0"
                                                                                  VerticalAlignment="Center">
                                                                                <Path Stroke="#2FB344"
                                                                                      StrokeThickness="1.7"
                                                                                      StrokeStartLineCap="Round"
                                                                                      StrokeEndLineCap="Round"
                                                                                      StrokeLineJoin="Round"
                                                                                      Data="M 1 5 L 3.75 7.75 L 9 2">
                                                                                    <Path.Style>
                                                                                        <Style TargetType="Path">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="True">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Path.Style>
                                                                                </Path>
                                                                                <Grid>
                                                                                    <Grid.Style>
                                                                                        <Style TargetType="Grid">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Grid.Style>
                                                                                    <Ellipse Stroke="#E25555" StrokeThickness="1.4"/>
                                                                                    <Path Stroke="#E25555"
                                                                                          StrokeThickness="1.4"
                                                                                          StrokeStartLineCap="Round"
                                                                                          StrokeEndLineCap="Round"
                                                                                          Data="M 2.7 2.7 L 7.3 7.3 M 7.3 2.7 L 2.7 7.3"/>
                                                                                </Grid>
                                                                                <TextBlock Text="?"
                                                                                           Foreground="#8FA0AF"
                                                                                           FontSize="10"
                                                                                           FontWeight="SemiBold"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsUnmarked}" Value="True">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Value}"
                                                                                       Foreground="#F5F1EB"
                                                                                       FontSize="11"
                                                                                       VerticalAlignment="Center"/>
                                                                            <Button Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Click="RemoveProblemNumberBtn_Click"
                                                                                    ToolTip="删除题号"
                                                                                    Style="{StaticResource ToolbarButton}"
                                                                                    Width="18"
                                                                                    Height="18"
                                                                                    MinWidth="18"
                                                                                    Padding="0"
                                                                                    Margin="5,0,0,0">
                                                                                <Path Width="10"
                                                                                      Height="12"
                                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                      StrokeThickness="1.4"
                                                                                      StrokeStartLineCap="Round"
                                                                                      StrokeEndLineCap="Round"
                                                                                      StrokeLineJoin="Round"
                                                                                      Data="M 3 3 L 9 3 L 8.3 11 L 3.7 11 Z M 2 2 L 10 2 M 5 1 L 7 1"/>
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <StackPanel Grid.Row="4"
                                                                    Orientation="Horizontal"
                                                                    Margin="0,5,0,0">
                                                            <TextBlock Text="实计"
                                                                       Foreground="#8FA0AF"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding ActualCompactDisplay}"
                                                                       Foreground="{Binding ActualForeground}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"
                                                                       MinWidth="34"/>
                                                            <StackPanel Orientation="Vertical" Margin="6,0,0,0">
                                                                <Button Content="+15m"
                                                                        Tag="15"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"/>
                                                                <Button Content="−15m"
                                                                        Tag="-15"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"
                                                                        Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                                                <Button Content="+5m"
                                                                        Tag="5"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"/>
                                                                <Button Content="−5m"
                                                                        Tag="-5"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"
                                                                        Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                                                <Button Content="+1m"
                                                                        Tag="1"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"/>
                                                                <Button Content="−1m"
                                                                        Tag="-1"
                                                                        CommandParameter="{Binding}"
                                                                        Click="AdjustPlanTaskActualTimeBtn_Click"
                                                                        IsEnabled="{Binding CanAdjustActualTime}"
                                                                        Style="{StaticResource DurationStepButton}"
                                                                        Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,18,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="长期任务"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#F5F1EB"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Click="ExpandLongTasksBtn_Click"
                                        ToolTip="展开长期任务详情"
                                        Width="32"
                                        MinWidth="32"
                                        Padding="0"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource ToolbarButton}">
                                    <Path Width="13" Height="13"
                                          Style="{StaticResource ButtonIconStrokePath}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M 1.5 5 L 1.5 1.5 L 5 1.5 M 8 1.5 L 11.5 1.5 L 11.5 5 M 11.5 8 L 11.5 11.5 L 8 11.5 M 5 11.5 L 1.5 11.5 L 1.5 8"/>
                                </Button>
                                <Button x:Name="AddLongTaskBtn"
                                         Grid.Column="2"
                                        Click="AddLongTaskBtn_Click"
                                        ToolTip="添加长期任务"
                                        Width="32"
                                        MinWidth="32"
                                        Padding="0"
                                        Style="{StaticResource ToolbarButton}">
                                    <Path Width="12" Height="12"
                                          Style="{StaticResource ButtonIconStrokePath}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M 6 1.5 L 6 10.5 M 1.5 6 L 10.5 6"/>
                                </Button>
                            </Grid>
                            <Border Grid.Row="4"
                                    Background="#151B21"
                                    BorderBrush="#3D4852"
                                    BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                    <ItemsControl x:Name="LongTaskItems"
                                                  Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1C242B"
                                                        BorderBrush="#2F3A44"
                                                        BorderThickness="1"
                                                        Padding="8"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="26"/>
                                                            <ColumnDefinition Width="26"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="#F5F1EB"
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ProgressDisplay}"
                                                                   Foreground="#FF9D45"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0"/>
                                                        <Button Grid.Column="2"
                                                                Tag="{Binding}"
                                                                Click="DecreaseLongTaskProgressBtn_Click"
                                                                ToolTip="进度减 1"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="22"
                                                                Height="26"
                                                                MinWidth="22"
                                                                Padding="0"
                                                                Margin="4,0,0,0">
                                                            <Path Width="10"
                                                                  Height="10"
                                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                  StrokeThickness="1.8"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  Data="M 1 5 L 9 5"/>
                                                        </Button>
                                                        <Button Grid.Column="3"
                                                                Tag="{Binding}"
                                                                Click="IncreaseLongTaskProgressBtn_Click"
                                                                ToolTip="进度加 1"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="22"
                                                                Height="26"
                                                                MinWidth="22"
                                                                Padding="0"
                                                                Margin="2,0,0,0">
                                                            <Path Width="10"
                                                                  Height="10"
                                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                  StrokeThickness="1.8"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  Data="M 1 5 L 9 5 M 5 1 L 5 9"/>
                                                        </Button>
                                                        <Button Grid.Column="4"
                                                                  Tag="{Binding}"
                                                                 Click="AddLongTaskToTodayBtn_Click"
                                                                 IsEnabled="{Binding CanAddToToday}"
                                                                ToolTip="加入或恢复今天"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="36"
                                                                Height="30"
                                                                MinWidth="36"
                                                                Padding="0"
                                                                Margin="2,0,0,0">
                                                            <Grid Width="14" Height="14">
                                                                <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                         StrokeThickness="1.6"/>
                                                                <Path Width="9" Height="9"
                                                                      Style="{StaticResource ButtonIconStrokePath}"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                      StrokeThickness="1.7"
                                                                      Data="M 4.5 1 L 4.5 8 M 1 4.5 L 8 4.5"/>
                                                            </Grid>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
