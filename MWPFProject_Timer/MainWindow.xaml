<Window x:Class="MWPFProject_Timer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MWPFProject_Timer"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown"
        Closing="Window_Closing"
        Width="230" Height="118"
        MinWidth="230" MinHeight="118"
        MaxWidth="230" MaxHeight="118">

    <Window.Resources>
        <Style x:Key="MiniButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1B1E22"/>
            <Setter Property="Background" Value="#F0F2F3"/>
            <Setter Property="BorderBrush" Value="#A8ADB2"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#F6F2EE"/>
            <Setter Property="Background" Value="#2E363E"/>
            <Setter Property="BorderBrush" Value="#4A5662"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3B4650"/>
                                <Setter Property="BorderBrush" Value="#FF7A1A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DayButton" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF9D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B20"/>
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="CaretBrush" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#3D4852"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="TaskTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#161B20"/>
            <Setter Property="Foreground" Value="#F5F1EB"/>
            <Setter Property="CaretBrush" Value="#FF7A1A"/>
            <Setter Property="BorderBrush" Value="#3D4852"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TaskTimeTextBox" TargetType="TextBox" BasedOn="{StaticResource TaskTextBox}">
            <Setter Property="Padding" Value="2,4"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TaskTimeUnitText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8D0D8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="RootBorder"
                BorderBrush="#555"
                BorderThickness="1"
                CornerRadius="0"
                Background="#40FFFFFF"
                Focusable="True">
            <Grid>
                <Grid x:Name="CompactPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="TaskUpBtn"
                            Content="↑"
                            Click="TaskUpBtn_Click"
                            Style="{StaticResource MiniButton}"/>
                    <Button x:Name="TaskDownBtn"
                            Grid.Row="2"
                            Content="↓"
                            Click="TaskDownBtn_Click"
                            Style="{StaticResource MiniButton}"/>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="当前任务:"
                                   Foreground="#1B1E22"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentTaskName"
                                   Text="未设置"
                                   Foreground="#1B1E22"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,8,0"/>
                        <TextBlock x:Name="CurrentTaskState"
                                   Text=""
                                   Foreground="#D84C4C"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,8,0"/>
                    </StackPanel>

                    <TextBlock x:Name="MinuteCounter"
                               Grid.Row="1"
                               Grid.Column="2"
                               Text="00:00"
                               Foreground="Black"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Border x:Name="CompactIndicator"
                            Grid.Column="2"
                            Width="8" Height="8"
                            Background="White"
                            Margin="0,6,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="1"/>

                    <StackPanel Grid.Row="2"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,6,0">
                        <Button x:Name="StartBtn"
                                Content="开"
                                Click="StartBtn_Click"
                                Style="{StaticResource MiniButton}"/>
                        <Button x:Name="StopBtn"
                                Content="停"
                                Click="StopBtn_Click"
                                Style="{StaticResource MiniButton}"/>
                        <Button x:Name="ResetBtn"
                                Content="重"
                                Click="ResetBtn_Click"
                                Style="{StaticResource MiniButton}"/>
                        <Button x:Name="ExpandBtn"
                                Content="展"
                                Click="ExpandBtn_Click"
                                Width="30"
                                Style="{StaticResource MiniButton}"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ExpandedPanel"
                      Visibility="Collapsed"
                      Background="#20262C">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="22,10,22,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border x:Name="ExpandedIndicator"
                                    Width="9" Height="9"
                                    Background="White"
                                    CornerRadius="2"
                                    Margin="0,0,8,0"/>
                            <TextBlock x:Name="ExpandedMinuteCounter"
                                       Text="00:00"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F1EB"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                x:Name="CollapseBtn"
                                Content="收"
                                Click="CollapseBtn_Click"
                                Style="{StaticResource ToolbarButton}"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="22,14,22,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="540"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#252D34"
                                BorderBrush="#3B4650"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Content="‹"
                                            Click="PrevMonthBtn_Click"
                                            Style="{StaticResource ToolbarButton}"/>
                                    <TextBlock x:Name="MonthTitle"
                                               Grid.Column="1"
                                               Text="2026年6月"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#F5F1EB"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Content="›"
                                            Click="NextMonthBtn_Click"
                                            Style="{StaticResource ToolbarButton}"/>
                                </Grid>

                                <UniformGrid Grid.Row="1"
                                             Columns="7"
                                             Margin="0,20,0,8">
                                    <TextBlock Text="一" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="二" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="三" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="四" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="五" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="六" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="日" Foreground="#AEB8C2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </UniformGrid>

                                <ItemsControl x:Name="CalendarDayItems"
                                              Grid.Row="2">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" Rows="6"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource DayButton}"
                                                    Click="CalendarDay_Click"
                                                    Tag="{Binding Date}"
                                                    Background="{Binding Background}"
                                                    BorderBrush="{Binding BorderBrush}">
                                                <Grid>
                                                    <TextBlock Text="{Binding DayText}"
                                                               Foreground="{Binding Foreground}"
                                                               FontWeight="{Binding FontWeight}"
                                                               Margin="8,6,0,0"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding TimeText}"
                                                               Foreground="{Binding TimeForeground}"
                                                               Visibility="{Binding TimeVisibility}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,18,4"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Ellipse Width="5" Height="5"
                                                             Fill="{Binding DotBrush}"
                                                             Visibility="{Binding DotVisibility}"
                                                             Margin="0,0,8,7"
                                                             HorizontalAlignment="Right"
                                                             VerticalAlignment="Bottom"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#FF7A1A"
                                CornerRadius="1"/>

                        <Grid Grid.Column="2" Margin="28,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="230"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="SelectedDateTitle"
                                       Text="2026年6月30日"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F1EB"
                                       TextWrapping="NoWrap"/>

                            <Grid Grid.Row="1" Margin="0,22,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="计划"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#F5F1EB"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <TextBox x:Name="TotalHoursBox"
                                         Grid.Column="1"
                                         MaxLength="2"
                                         TextChanged="TotalPlanTextChanged"
                                         LostFocus="TotalPlanTimeLostFocus"
                                         PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                         Style="{StaticResource TaskTimeTextBox}"/>
                                <TextBlock Grid.Column="2"
                                           Text="小时"
                                           Style="{StaticResource TaskTimeUnitText}"/>
                                <TextBox x:Name="TotalMinutesBox"
                                         Grid.Column="3"
                                         MaxLength="2"
                                         TextChanged="TotalPlanTextChanged"
                                         LostFocus="TotalPlanTimeLostFocus"
                                         PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                         Style="{StaticResource TaskTimeTextBox}"/>
                                <TextBlock Grid.Column="4"
                                           Text="分钟"
                                           Style="{StaticResource TaskTimeUnitText}"/>
                                <Button x:Name="AddTaskBtn"
                                        Grid.Column="6"
                                        Content="+ 添加"
                                        Click="AddTaskBtn_Click"
                                        Style="{StaticResource ToolbarButton}"/>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="#151B21"
                                    BorderBrush="#3D4852"
                                    BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                    <ItemsControl x:Name="PlanTaskItems"
                                                  Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1C242B"
                                                        BorderBrush="#2F3A44"
                                                        BorderThickness="1"
                                                        Padding="8"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="38"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="38"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsReadOnly="{Binding IsReadOnly}"
                                                                 TextChanged="PlanTaskTextChanged"
                                                                 PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTextBox}"/>

                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding PlannedHoursText, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsReadOnly="{Binding IsReadOnly}"
                                                                 MaxLength="2"
                                                                 TextChanged="PlanTaskTextChanged"
                                                                 LostFocus="PlanTaskTimeLostFocus"
                                                                 PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTimeTextBox}"
                                                                 Margin="8,0,0,0"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="小时"
                                                                   Style="{StaticResource TaskTimeUnitText}"/>
                                                        <TextBox Grid.Column="3"
                                                                 Text="{Binding PlannedMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsReadOnly="{Binding IsReadOnly}"
                                                                 MaxLength="2"
                                                                 TextChanged="PlanTaskTextChanged"
                                                                 LostFocus="PlanTaskTimeLostFocus"
                                                                 PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTimeTextBox}"/>
                                                        <TextBlock Grid.Column="4"
                                                                   Text="分钟"
                                                                   Style="{StaticResource TaskTimeUnitText}"/>

                                                        <Button Grid.Column="5"
                                                                Content="x"
                                                                Tag="{Binding}"
                                                                Click="RemoveTaskBtn_Click"
                                                                IsEnabled="{Binding CanEdit}"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="24"
                                                                Height="30"
                                                                MinWidth="24"
                                                                Padding="0"
                                                                Margin="6,0,0,0"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Grid.ColumnSpan="4"
                                                                   Text="{Binding ActualDisplay}"
                                                                   Visibility="{Binding ActualVisibility}"
                                                                   Foreground="#8FA0AF"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,4,8,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,18,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="长期任务"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#F5F1EB"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="AddLongTaskBtn"
                                        Grid.Column="1"
                                        Content="+ 添加"
                                        Click="AddLongTaskBtn_Click"
                                        Style="{StaticResource ToolbarButton}"/>
                            </Grid>
                            <Border Grid.Row="4"
                                    Background="#151B21"
                                    BorderBrush="#3D4852"
                                    BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                    <ItemsControl x:Name="LongTaskItems"
                                                  Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1C242B"
                                                        BorderBrush="#2F3A44"
                                                        BorderThickness="1"
                                                        Padding="8"
                                                        Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition Width="46"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="LongTaskTextChanged"
                                                                 PreviewKeyDown="LongTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTextBox}"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding ProgressText, UpdateSourceTrigger=PropertyChanged}"
                                                                 MaxLength="3"
                                                                 TextChanged="LongTaskTextChanged"
                                                                 LostFocus="LongTaskProgressLostFocus"
                                                                 PreviewKeyDown="LongTaskInput_PreviewKeyDown"
                                                                 Style="{StaticResource TaskTimeTextBox}"
                                                                 Margin="8,0,0,0"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="%"
                                                                   Style="{StaticResource TaskTimeUnitText}"/>
                                                        <Button Grid.Column="3"
                                                                Content="加入"
                                                                Tag="{Binding}"
                                                                Click="AddLongTaskToTodayBtn_Click"
                                                                IsEnabled="{Binding CanAddToToday}"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="36"
                                                                Height="30"
                                                                MinWidth="36"
                                                                Padding="0"
                                                                Margin="2,0,0,0"/>
                                                        <Button Grid.Column="4"
                                                                Content="x"
                                                                Tag="{Binding}"
                                                                Click="RemoveLongTaskBtn_Click"
                                                                Style="{StaticResource ToolbarButton}"
                                                                Width="24"
                                                                Height="30"
                                                                MinWidth="24"
                                                                Padding="0"
                                                                Margin="6,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
