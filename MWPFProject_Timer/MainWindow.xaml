                                         TextChanged="TotalPlanTextChanged"
                                         LostFocus="TotalPlanTimeLostFocus"
                                         PreviewKeyDown="PlanTaskInput_PreviewKeyDown"
                                         Style="{StaticResource TaskTimeTextBox}"/>
