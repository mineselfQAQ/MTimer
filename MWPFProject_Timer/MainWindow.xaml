                                                                            CommandParameter="{Binding}"
                                                                            Click="AdjustPlanTaskDurationBtn_Click"
                                                                            Style="{StaticResource DurationStepButton}"
                                                                            Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                                                    <Button Content="+5m"
                                                                            Tag="5"
                                                                            CommandParameter="{Binding}"
                                                                            Click="AdjustPlanTaskDurationBtn_Click"
                                                                            Style="{StaticResource DurationStepButton}"/>
